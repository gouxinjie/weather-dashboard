# 和风天气 API Key（从和风天气控制台获取）
QWEATHER_API_KEY=your_qweather_api_key_here

# 和风天气控制台分配的专属 API Host（不要带 https://）
QWEATHER_API_HOST=your-api-host.example.com

# 服务端口
PORT=4000

# 默认城市 LocationID
DEFAULT_LOCATION_ID=101010100

# 默认城市名称
DEFAULT_CITY_NAME=北京

# 数据库文件路径
DB_PATH=./data/weather.db

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 数据保留天数
SNAPSHOT_RETENTION_DAYS=90
